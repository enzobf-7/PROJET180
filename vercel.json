{
  "framework": "nextjs",
  "regions": ["cdg1"],
  "functions": {
    "src/app/api/webhooks/stripe/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/weekly-reports/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/weekly-reports",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/habit-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/milestone-emails",
      "schedule": "0 8 * * *"
    }
  ]
}
